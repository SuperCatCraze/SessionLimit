<Window x:Class="SessionLimit.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="Height" Width="330" Focusable="False" ShowActivated="False">

  <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Stroke}"
          BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="8">
    <Border.Effect>
      <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.55" Color="Black"/>
    </Border.Effect>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="4"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Border x:Name="AccentBar" Grid.Column="0" Background="{StaticResource Warn}"
              CornerRadius="2" Margin="0,0,10,0"/>

      <StackPanel Grid.Column="1">
        <TextBlock x:Name="TitleText" Foreground="{StaticResource Fg}" FontFamily="Segoe UI"
                   FontSize="12" FontWeight="SemiBold" Text="Session Limit"/>
        <TextBlock x:Name="BodyText" Foreground="{StaticResource FgDim}" FontFamily="Segoe UI"
                   FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" Text=""/>
      </StackPanel>

      <Button Grid.Column="2" Content="✕" Style="{StaticResource IconBtn}"
              VerticalAlignment="Top" Click="Close_Click"/>
    </Grid>
  </Border>
</Window>
